aspace:
  base_url: https://archivesspace.example.edu/api
  username: ""
  password: ""
  # List of repository IDs to process. Empty list = all repositories.
  repository_ids: []
  # Public hostname used to build collection URLs for FOLIO electronic access matching.
  public_domain: archivesspace.example.edu

folio:
  gateway_url: https://folio.example.org
  tenant_id: ""
  username: ""
  password: ""
  # The FOLIO user must have the following permissions:
  #   inventory-storage.holdings-types.collection.get
  #   inventory-storage.holdings.collection.get
  #   inventory-storage.holdings.item.delete
  #   inventory-storage.holdings.item.post
  #   inventory-storage.holdings.item.put
  #   inventory-storage.holdings-sources.collection.get

  #   inventory-storage.items.collection.get
  #   inventory-storage.items.item.delete
  #   inventory-storage.items.item.post
  #   inventory-storage.items.item.put
  #   inventory-storage.loan-types.collection.get
  #   inventory-storage.locations.collection.get
  #   inventory-storage.material-types.collection.get
  #   inventory-storage.statistical-codes.collection.get
  #   search.instances.collection.get

filters:
  # Set to null or remove key to skip that filter.
  published: true
  finding_aid_status: "completed"

mapping:
  managed_statistical_code: "MANAGED_VIA_ARCHIVESSPACE"
  suppressed_statistical_code: "SUPPRESSED_VIA_ARCHIVESSPACE"

  holdings:
    type: "Physical"
    source: "FOLIO"
    # Field mappings — keys are FOLIO field names (camelCase); values are either:
    #   - A format string with {aspace_field_name} tokens (e.g. "{id_0} {id_1}")
    #   - A function reference "fn:function_name" for complex logic (defined in field_functions.py)
    # Structural fields (instanceId, permanentLocationId, sourceId, etc.) are set by the engine.
    fields:
      callNumber: "{id_0} {id_1}"
      # callNumberPrefix: "SC"
      # callNumberSuffix: "fn:my_suffix_function"

  items:
    material_type: "unspecified"
    permanent_loan_type: "Reading room"
    # Field mappings — same format as holdings.fields above.
    # Structural fields (holdingsRecordId, barcode, materialTypeId, etc.) are set by the engine.
    fields:
      itemLevelCallNumber: "{display_string} {collection_identifier_stored_u_sstr}"
      # enumeration: "{indicator}"
      # chronology: "fn:my_chronology_function"

  # Whether to suppress existing non-managed holdings (and their items) when a new managed holdings is added.
  suppress_non_managed_holdings: true

  # Mapping from ASpace location ID (integer) to FOLIO location name.
  # The FOLIO location UUID is looked up at startup by name.
  location_map:
    # 12345: "Main Library Stacks"

  # Fallback FOLIO location name for TLCs with no ASpace location set.
  # default_location: "Main Library Stacks"
